# PROJECT VOID — environment variables
# Copy to .env.local and fill in. On Vercel, add these in Project → Settings → Environment Variables.
#
# Razorpay keys: Dashboard → Account & Settings → API Keys.
# Use rzp_test_* keys for a prototype (no real money); rzp_live_* charges real cards.

# Server-only (NEVER expose to the browser):
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret_here

# Public (safe to expose; used by Razorpay Checkout in the browser):
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
